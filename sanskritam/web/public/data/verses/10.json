[
  {
    "id": 63,
    "chapter_id": 10,
    "verse_number": "7.1",
    "content_sanskrit": "ततः स विश्वरूपस्य गृहं वव्राज सङ्करः ।\nकिमप्यबोधतापाङ्गवीक्षया तत्प्रियाऽमुना",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 1
  },
  {
    "id": 64,
    "chapter_id": 10,
    "verse_number": "7.2",
    "content_sanskrit": "जघटाते तयोर्मङ्क्षु चेतसी त्वितरेतरम् ।\nनिलीनोऽध्वनयद्भिक्षुर्निशीथे प्राङ्गणाद्बहिः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 2
  },
  {
    "id": 65,
    "chapter_id": 10,
    "verse_number": "7.3",
    "content_sanskrit": "हा हा बीजादैष गूढो मदीयो भूयस्तात व्यापृतोऽहं गुणेषु । किं वास्माकं भावि का वा गतिः स्यादित्थं जल्पन्नाप दीर्घा स निद्राम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 3
  },
  {
    "id": 1782985730743,
    "chapter_id": 10,
    "verse_number": "7.4",
    "content_sanskrit": "बृहत्तमोद्धताङ्गेन ।\nतेन दुर्भिक्षुणोत्तुङ्गजघनस्तनयारमि",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 4
  },
  {
    "id": 1782985730744,
    "chapter_id": 10,
    "verse_number": "7.5",
    "content_sanskrit": "पत्युरेत्य शनैर्नारी समीपेऽशेतविक्लवा ।\nकूश्माण्डकथया चैनं प्रबुध्यतमबोधयत्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 5
  },
  {
    "id": 1782985730745,
    "chapter_id": 10,
    "verse_number": "7.6",
    "content_sanskrit": "ततः प्रातर्विवादेच्छुः सङ्करो विप्रमब्रवीत् ।\nजल्पावः प्राश्लिकत्वेऽसौ कल्प्यतां दयिता तव",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 6
  },
  {
    "id": 1782985730746,
    "chapter_id": 10,
    "verse_number": "7.7",
    "content_sanskrit": "स आश्रमान्तरं प्रायाद्यः पराभवमेष्यति ।\nइत्युक्तवा तेन सोऽजल्पत्सा पतिं जितमब्रवीत्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 7
  },
  {
    "id": 1782985730747,
    "chapter_id": 10,
    "verse_number": "7.8",
    "content_sanskrit": "ततः पर्यव्रजद्विप्रस्तया रेमे च सङ्करः ।\nक्वचित्तेनासुरेशेन पर्यपश्यत्स मण्डनः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 8
  },
  {
    "id": 1782985730748,
    "chapter_id": 10,
    "verse_number": "7.9",
    "content_sanskrit": "यो भट्टेन पराभूतो बहुशास्तराणि शुश्रुवान् ।\nनिर्ययौ वारणारूढः सन्तं सङ्कुरमब्रवीत्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 9
  },
  {
    "id": 1782985730749,
    "chapter_id": 10,
    "verse_number": "7.10",
    "content_sanskrit": "कुतो मुण्ड इति प्राह आगलान्मुण्ड इत्यमुम् ।\nमण्डनस्त्वाह पन्थानं पृच्छामीत्यथ सोऽब्रवीत्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 10
  },
  {
    "id": 1782985730750,
    "chapter_id": 10,
    "verse_number": "7.11",
    "content_sanskrit": "किमाह पन्था इति ते माता रण्डेति मण्डनः ।\nस्माह तं भिक्षुकः सत्यमाह पन्था इति च्छलम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 11
  },
  {
    "id": 1782985730751,
    "chapter_id": 10,
    "verse_number": "7.12",
    "content_sanskrit": "निगृहीतेऽप्रतिभया भैरव्या कुक्कुटेन च ।\nक्षोभितो ब्राह्मणः शीघ्रमन्ववर्तत भिक्षुकम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 12
  },
  {
    "id": 1782985730752,
    "chapter_id": 10,
    "verse_number": "7.13",
    "content_sanskrit": "तोटकः पद्मपादश्च ज्ञानोच्चो बीजभुक तथा ।\nइत्येते मायिनः शिष्या आसंश्चत्वार",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 13
  },
  {
    "id": 1782985730753,
    "chapter_id": 10,
    "verse_number": "7.14",
    "content_sanskrit": "सिद्धित्रयमकार्षुस्ते शिष्या ज्ञानोत्तमादयः ।\nतोटकादीनि चत्वारि तामसाख्यनिरर्गलम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 14
  },
  {
    "id": 1782985730754,
    "chapter_id": 10,
    "verse_number": "7.15",
    "content_sanskrit": "तेषां शिष्यप्रशिष्याद्या यत्याभासास्चतुर्विधाः ।\nअबृंहयत वंशान् स्वान् न्यसयन्तः पृथग्जनान्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 15
  },
  {
    "id": 1782985730755,
    "chapter_id": 10,
    "verse_number": "7.16",
    "content_sanskrit": "दक्षिणाशां ततो गत्वा दग्ध्वा मातुः कलेवरम् ।\nआगत्य स्वमठं प्राप्य सङ्करो रोगपीडितः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 16
  },
  {
    "id": 1782985730756,
    "chapter_id": 10,
    "verse_number": "7.17",
    "content_sanskrit": "ततः काले समायाते श्वासज्वरभगन्दरैः ।\nदुःखाद्यैः पीडितस्यास्य वाणी किञ्चिदलीयत",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 17
  },
  {
    "id": 1782985730757,
    "chapter_id": 10,
    "verse_number": "7.18",
    "content_sanskrit": "मुमूर्षु स्वगुरुं दृष्टवा मायिनो वेदविद्विषः ।\nभगवान् नः परं कृत्यं किमपृच्छन्ससम्भ्रमः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 18
  },
  {
    "id": 1782985730758,
    "chapter_id": 10,
    "verse_number": "7.19",
    "content_sanskrit": "स स्माह तान् कृतप्रायं सत्यं कृत्यं महासुरः ।\nउत्साद्यतामथ क्षिप्रं परतीर्थार्यशिष्यकाः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 19
  },
  {
    "id": 1782985730759,
    "chapter_id": 10,
    "verse_number": "7.20",
    "content_sanskrit": "परतीर्थः प्रकृत्यैव शापानुग्रहशक्तिमान् ।\nप्रवया अत्यजत्तनुम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 20
  },
  {
    "id": 1782985730760,
    "chapter_id": 10,
    "verse_number": "7.21",
    "content_sanskrit": "सत्यप्रज्ञो दुराधर्षः शक्तोऽपीह हरिद्विषाम् ।\nऋषिभ्यो हिमवत्पृष्ठे",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 21
  },
  {
    "id": 1782985730761,
    "chapter_id": 10,
    "verse_number": "7.22",
    "content_sanskrit": "तच्छिष्यो निपुणशशान्तो वेदवेदान्तकोविदः ।\nशिष्येभः पञ्चषेभ्यस्तपोमयः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 22
  },
  {
    "id": 1782985730762,
    "chapter_id": 10,
    "verse_number": "7.23",
    "content_sanskrit": "नान्योऽस्ति सम्प्रदायज्ञः श्रुतेर्दैतेयपुङ्खवाः ।\nएत्य हंसानिमान् क्षिप्रमुत्सादयत निर्भयाः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 23
  },
  {
    "id": 1782985730763,
    "chapter_id": 10,
    "verse_number": "7.24",
    "content_sanskrit": "आदिश्येत्थं बलवतः शिष्यानन्यान्महासुरान् ।\nआहूय चतुरो दैत्यानाहान्तेवासिनोऽसुरः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 24
  },
  {
    "id": 1782985730764,
    "chapter_id": 10,
    "verse_number": "7.25",
    "content_sanskrit": "बीजादं शृणुतास्माकमेष्यन्तं भवसङ्कटम् ।\nइत्युक्तास्ते दशदिशः परिभ्रम्य समागताः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 25
  },
  {
    "id": 1782985730765,
    "chapter_id": 10,
    "verse_number": "7.26",
    "content_sanskrit": "किमपङ्यत बीजादः किमवोचत्स मे गतिम् ।\nइत्युक्तास्ते स्वगुरुणा रहस्तं प्रत्यचक्षत",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 26
  },
  {
    "id": 1782985730766,
    "chapter_id": 10,
    "verse_number": "7.27",
    "content_sanskrit": "गुरोः का नो गतिरिति दृष्टं दृष्टं नरं प्रति ।\nविचार्याप्युत्तरं नाप्तमित्येकः पुनरब्रवीत्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 27
  },
  {
    "id": 1782985730767,
    "chapter_id": 10,
    "verse_number": "7.28",
    "content_sanskrit": "द्वयं सङ्करस्यास्ति पद्मस्य चैकं\nममैकं च नैकं नैकं च नास्ति ।\nगिरेत्येतया कन्दुकक्रीडमेक-\nमवेक्ष्येऽन्त्यजं पङ्कणान्ते क्वचेति",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 28
  },
  {
    "id": 1782985730768,
    "chapter_id": 10,
    "verse_number": "7.29",
    "content_sanskrit": "हा हा बीजादैष गूढो मदीयो\nभूयस्तात व्यापृतोऽहं गुणेषु ।\nकिं वास्माकं भावि का वा गतिः स्या-\nदित्थं जल्पन्नाप दीर्घा स निद्राम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 29
  }
]