[
  {
    "id": 49,
    "chapter_id": 6,
    "verse_number": "3.1",
    "content_sanskrit": "हिमांशोरत्रिपुत्रस्य बुधो नाम सुतोऽभवत् ।\nपुरूरवा महाराजः तस्य पुत्रो व्यजायत",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 1
  },
  {
    "id": 50,
    "chapter_id": 6,
    "verse_number": "3.2",
    "content_sanskrit": "तस्याऽऽयुरभवत्पुत्रो नहुषस्तस्य नन्दनः ।\nययातिरभवत्तस्य नन्दनो बलवीर्यवान्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 2
  },
  {
    "id": 51,
    "chapter_id": 6,
    "verse_number": "3.3",
    "content_sanskrit": "ज्ञानानन्दतनुं श्यामं शंखचक्रगदाधरम् ।व्यक्तमात्रं हरिं दृष्ट्वा तुष्टावानकदुन्दुभिः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 3
  },
  {
    "id": 52,
    "chapter_id": 6,
    "verse_number": "3.4",
    "content_sanskrit": "स पालयन्गोपकबालवृन्दैर्बलेन साकं पशुवत्सयूथान् । निहत्य वत्सासुरमादिदेवो बकं च गोपालकतामवाप",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 4
  },
  {
    "id": 1782985139922,
    "chapter_id": 6,
    "verse_number": "3.5",
    "content_sanskrit": "यदोर्वशे तु राजानः कार्तवीर्यपुरोगमाः ।\nबभूवुर्भगवद्भक्ताः तपोज्ञानपरायणाः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 5
  },
  {
    "id": 1782985139923,
    "chapter_id": 6,
    "verse_number": "3.6",
    "content_sanskrit": "पुरोर्वशे तु राजान आसन् दौष्यन्तिपूर्वकाः ।\nतेषां कीर्त्या च विक्रान्त्या समस्ताः पूरिता दिशः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 6
  },
  {
    "id": 1782985139924,
    "chapter_id": 6,
    "verse_number": "3.7",
    "content_sanskrit": "भूमारहरणापेक्षाः तस्मिन्काले दिवौकसः ।\nदुग्धाब्धिशायिनं विष्णुं शरण्यं शरणं ययुः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 7
  },
  {
    "id": 1782985139925,
    "chapter_id": 6,
    "verse_number": "3.8",
    "content_sanskrit": "विप्रक्षत्रादिभावेन तदादिष्टाः सुरादयः ।\nबभूवुर्भगवत्सेवां विधित्सन्तः समस्तशः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 8
  },
  {
    "id": 1782985139926,
    "chapter_id": 6,
    "verse_number": "3.9",
    "content_sanskrit": "वरुणश्शन्तनुर्नाम पुरोर्वंशे व्यजायत ।\nविचित्रवीर्यस्तस्यासी-त्पुत्रश्चित्राङ्गदानुजः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 9
  },
  {
    "id": 1782985139927,
    "chapter_id": 6,
    "verse_number": "3.10",
    "content_sanskrit": "धृतराष्ट्रश्च पाण्डुश्च इति पुत्रौ बभूवतुः ।\nपाण्डोः कुन्ती च माद्री च द्वे भार्ये धर्मकोविदे",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 10
  },
  {
    "id": 1782985139928,
    "chapter_id": 6,
    "verse_number": "3.11",
    "content_sanskrit": "स पाण्डुर्मुनिशापेन स्रीसङ्गमसुखं जहौ ।\nभत्राज्ञया सुतं कुन्ती धर्माल्लेभे युधिष्ठिरम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 11
  },
  {
    "id": 1782985139929,
    "chapter_id": 6,
    "verse_number": "3.12",
    "content_sanskrit": "धृतराष्ट्रस्य गांधार्यामासन् दुर्योधनादयः ।\nवधाय मारुतस्तेषां भीमं कुन्त्यामजीजनत्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 12
  },
  {
    "id": 1782985139930,
    "chapter_id": 6,
    "verse_number": "3.13",
    "content_sanskrit": "सा लेभे वासवाज्जिष्णुं यमौ माद्री च दस्रयोः ।\nवनेऽवर्धन्त वत्सास्ते पाण्डुना परिरक्षिताः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 13
  },
  {
    "id": 1782985139931,
    "chapter_id": 6,
    "verse_number": "3.14",
    "content_sanskrit": "एवं पाञ्चालबह्लीका अवर्धन्त महाबलाः ।\nआहुकाद्यादवादुग्र-सेनोऽभूद्देवकस्तथा",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 14
  },
  {
    "id": 1782985139932,
    "chapter_id": 6,
    "verse_number": "3.15",
    "content_sanskrit": "देवकस्य सुता जज्ञे देवकी देवसंमता ।\nवसुदेव उवाहैनां यादवः शूरनन्दनः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 15
  },
  {
    "id": 1782985139933,
    "chapter_id": 6,
    "verse_number": "3.16",
    "content_sanskrit": "तत्र प्रादुरभूद्देवः परमात्मा सनातनः ।\nदुंपत्योरनयोराशाः पूरयन्त्सुरकार्यवान्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 16
  },
  {
    "id": 1782985139934,
    "chapter_id": 6,
    "verse_number": "3.17",
    "content_sanskrit": "वसुदेवस्य रोहिण्यां ततः पूर्वमजायत ।\nअनन्तो बलवत्वेन बलभद्र इति श्रुतः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 17
  },
  {
    "id": 1782985139935,
    "chapter_id": 6,
    "verse_number": "3.18",
    "content_sanskrit": "ज्ञानानन्दतनुं श्यामं शंखचक्रगदाधरम् ।\nव्यक्तमात्रं हरिं दृष्ट्वा तुष्टावानकदुन्दुभिः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 18
  },
  {
    "id": 1782985139936,
    "chapter_id": 6,
    "verse_number": "3.19",
    "content_sanskrit": "स्वाज्ञया स व्रजं नीतः कंसाद्भीतेन शौरिणा ।\nशिशुरूपो यशोदायाः शायितः शयने शनैः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 19
  },
  {
    "id": 1782985139937,
    "chapter_id": 6,
    "verse_number": "3.20",
    "content_sanskrit": "चण्डिकां तत्क्षणोद्भूतां नीत्वा यादवनन्दनः ।\nदेवक्याः शयने न्यस्य पूर्ववद् बन्धमाययौ",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 20
  },
  {
    "id": 1782985139938,
    "chapter_id": 6,
    "verse_number": "3.21",
    "content_sanskrit": "तां कन्यां कंस आनीय निहन्तुमुपचक्रमे ।\nमृत्युस्ते जात इत्युक्त्वा सोत्पपात नमस्थलम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 21
  },
  {
    "id": 1782985139939,
    "chapter_id": 6,
    "verse_number": "3.22",
    "content_sanskrit": "जातमात्रान्कुमारान्स निहन्तुमुपचक्रमे ।\nहिंसाविहारा दुष्टास्ते निजघ्नुबालकान्भुवि",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 22
  },
  {
    "id": 1782985139940,
    "chapter_id": 6,
    "verse_number": "3.23",
    "content_sanskrit": "जगाम गोकुलं दुष्टा धात्री कंसस्य पूतना ।\nकृष्णमादत्त सा हन्तुं तां जघान रमापतिः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 23
  },
  {
    "id": 1782985139941,
    "chapter_id": 6,
    "verse_number": "3.24",
    "content_sanskrit": "शायितः शकटस्याधः शकटाक्षं जघान सः ।\nअमीमरत्तृणावर्तं तेनोन्नीतः स लीलया",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 24
  },
  {
    "id": 1782985139942,
    "chapter_id": 6,
    "verse_number": "3.25",
    "content_sanskrit": "गर्गोऽथ शौरिणादिष्टश्चकार क्षत्रियोचितान् ।\nसंस्कारान्नाम चामुष्य सबलस्य व्रजं गतः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 25
  },
  {
    "id": 1782985139943,
    "chapter_id": 6,
    "verse_number": "3.26",
    "content_sanskrit": "प्राङ्गणे रिखणं कुर्वन् अर्भकैः सह माधवः ।\nलीलाभिर्भावगर्भाभिः जनमानन्दयन् बभौ",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 26
  },
  {
    "id": 1782985139944,
    "chapter_id": 6,
    "verse_number": "3.27",
    "content_sanskrit": "जघास मृत्तिकां देवः कदाचिल्लीलया हरिः ।\nमात्रोपालब्ध आस्ये स्वे व्यात्ते विश्वमदर्शयत्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 27
  },
  {
    "id": 1782985139945,
    "chapter_id": 6,
    "verse_number": "3.28",
    "content_sanskrit": "दध्यमत्रं विभज्येशः कदाचिच्चन्द्रसन्निभम् ।\nनवनीतं समादाय रहो गत्वा जघास च",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 28
  },
  {
    "id": 1782985139946,
    "chapter_id": 6,
    "verse_number": "3.29",
    "content_sanskrit": "जनन्योलूखले बद्धः सोऽर्जुनावुदमूलयत् ।\nनलकूबरमणिग्रीवौ मोचयामास शापतः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 29
  },
  {
    "id": 1782985139947,
    "chapter_id": 6,
    "verse_number": "3.30",
    "content_sanskrit": "वृन्दावनमियासुः सन् नन्दसूनुर्बृहद्वने ।\nससर्ज रोमकूपेभ्यो वृकान् व्याघ्रसमान् बले",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 30
  },
  {
    "id": 1782985139948,
    "chapter_id": 6,
    "verse_number": "3.31",
    "content_sanskrit": "तत्रोत्पातभिया गोपा आपुर्वृन्दावनं वनम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 31
  },
  {
    "id": 1782985139949,
    "chapter_id": 6,
    "verse_number": "3.32",
    "content_sanskrit": "स पालयन्गोपकबालवृन्दै-\nर्बलेन साकं पशुवत्सयूथान् ।\nनिहत्य वत्सासुरमादिदेवो\nबकं च गोपालकतामवाप",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 32
  }
]