[
  {
    "id": 57,
    "chapter_id": 8,
    "verse_number": "5.1",
    "content_sanskrit": "ततः परमहंसा ये कृष्णभीमानुशिक्षिताः ।\nव्यासाश्रयादत्रिजाद्या वेदशास्त्राण्यवर्तयन्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 1
  },
  {
    "id": 58,
    "chapter_id": 8,
    "verse_number": "5.2",
    "content_sanskrit": "कृष्णे भीमे च विद्वेषमधिकं दधतोऽसुराः ।\nभग्नबाहुबला ईषुर्वाग्युद्धैस्तत्वविस्रवम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 2
  },
  {
    "id": 59,
    "chapter_id": 8,
    "verse_number": "5.3",
    "content_sanskrit": "वेदोऽप्रमाणमित्युक्त्वा बुद्धस्तानप्यमोहयत् ।बौद्धशास्त्रं ततस्तेनुरज्ञात्वा तन्मतं परम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 3
  },
  {
    "id": 60,
    "chapter_id": 8,
    "verse_number": "5.4",
    "content_sanskrit": "वह्निप्रवेशग्लहया कुमारोवितण्डया माध्यमिकान्निगृह्य ।नष्टायुषोऽपह्नवतः श्रुतीनामह्नाय वह्नौ गमयाञ्चकार",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 4
  },
  {
    "id": 1782985482427,
    "chapter_id": 8,
    "verse_number": "5.5",
    "content_sanskrit": "दुर्धर्षा भीमसेनो नः कृष्णोऽप्यत्यन्तदुःसहः ।\nताभ्यां निरीक्षिता दैत्या मृत्युं यान्ति न संशयः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 5
  },
  {
    "id": 1782985482428,
    "chapter_id": 8,
    "verse_number": "5.6",
    "content_sanskrit": "कृष्णो दैवं गुरुर्भीमो वेदविद्या च पार्वती ।\nतस्या उत्सादनेनैव यातस्तावतिसङ्कटम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 6
  },
  {
    "id": 1782985482429,
    "chapter_id": 8,
    "verse_number": "5.7",
    "content_sanskrit": "तस्माज्जनेषु विद्वत्सु वेदव्याख्यानशालिषु ।\nप्रविश्योत्साद्यतां विद्या कैश्चिदुत्पद्य भूतले",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 7
  },
  {
    "id": 1782985482430,
    "chapter_id": 8,
    "verse_number": "5.8",
    "content_sanskrit": "विपरीतानि शास्त्राणि कर्तव्यानि बहून्यपि ।\nवेदविद्यानिरस्यताम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 8
  },
  {
    "id": 1782985482431,
    "chapter_id": 8,
    "verse_number": "5.9",
    "content_sanskrit": "वेदशास्त्रान्ननो भीतिरस्ति कार्यान्तरस्पृहाम् ।\nलोकायतमतं मानहीनं नाद्रियते जनैः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 9
  },
  {
    "id": 1782985482432,
    "chapter_id": 8,
    "verse_number": "5.10",
    "content_sanskrit": "अक्षपादः कणादश्च कपिलञ्चापरो जनः ।\nशास्त्रान्तराणि कृत्वापि वेदद्वेषं न कुर्वते",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 10
  },
  {
    "id": 1782985482433,
    "chapter_id": 8,
    "verse_number": "5.11",
    "content_sanskrit": "हरेण निहताः पूर्वं त्रैपुरा असुराः पुनः ।\nजाताः संसर्गदोषेण पामराः श्रद्धधुस्तियाम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 11
  },
  {
    "id": 1782985482434,
    "chapter_id": 8,
    "verse_number": "5.12",
    "content_sanskrit": "वेदोऽप्रमाणमित्युक्तवा बुद्धस्तानप्यमोहयत्'' ।\nबौद्धशास्त्रं ततस्तेनुरज्ञात्वा तन्मतं परम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 12
  },
  {
    "id": 1782985482435,
    "chapter_id": 8,
    "verse_number": "5.13",
    "content_sanskrit": "निराश्रमान् दुराचारान् प्रत्यक्षं द्विषतः श्रुतीः ।\nब्राह्मणा गर्हयन्त्येतान् वेदबाह्यानकौशलान्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 13
  },
  {
    "id": 1782985482436,
    "chapter_id": 8,
    "verse_number": "5.14",
    "content_sanskrit": "जैनपाशुपताद्याश्च लोकविद्वूषगोचराः ।\nवेदविद्वषिणोऽप्येते तत्रोपायं न जानते",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 14
  },
  {
    "id": 1782985482437,
    "chapter_id": 8,
    "verse_number": "5.15",
    "content_sanskrit": "सर्वान् वेदान् द्विजो भूत्वा श्रितः परममाश्रमम् ।\nवेदान्तिव्यपदेशेन निरस्यन्नः परः सुहृत्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 15
  },
  {
    "id": 1782985482438,
    "chapter_id": 8,
    "verse_number": "5.16",
    "content_sanskrit": "अस्मिन् कार्ये विदग्धोऽयं मणिमानेव दृश्यते ।\nआदेष्टव्योऽमुना राज्ञा कलिना कार्यसिद्धये",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 16
  },
  {
    "id": 1782985482439,
    "chapter_id": 8,
    "verse_number": "5.17",
    "content_sanskrit": "एवमुक्ता द्वापरेण कलिपूर्वाः सुरद्विषः ।\nहृष्टा आहूय सम्भाव्य मणिमन्तं बभाषिरे",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 17
  },
  {
    "id": 1782985482440,
    "chapter_id": 8,
    "verse_number": "5.18",
    "content_sanskrit": "याहि भ्रातर्नमस्तुभ्यमुत्पद्यस्व महीतले ।\nविद्यावेदपुराणाद्याः भृशं विस्रावय द्रुतम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 18
  },
  {
    "id": 1782985482441,
    "chapter_id": 8,
    "verse_number": "5.19",
    "content_sanskrit": "विदूषय गुणान् विष्णोर्जीवैक्यं प्रतिपादय ।\nभूमौ वृकोदराभावान्नाशङ्कां कर्तुमर्हसि",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 19
  },
  {
    "id": 1782985482442,
    "chapter_id": 8,
    "verse_number": "5.20",
    "content_sanskrit": "अस्मासु बद्धवैरः सन् स्वस्थोऽप्यस्वस्थतां गतः ।\nअनुज्ञाभावतो विष्णोर्नाधुनावतरत्ययम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 20
  },
  {
    "id": 1782985482443,
    "chapter_id": 8,
    "verse_number": "5.21",
    "content_sanskrit": "वंश्यास्तु सनकादीनामधुना यतयो भुवि ।\nएकदण्डास्त्रिदण्डाश्च वर्तन्ते तदनुव्रताः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 21
  },
  {
    "id": 1782985482444,
    "chapter_id": 8,
    "verse_number": "5.22",
    "content_sanskrit": "परतीर्थाभिधस्तत्र यतिरेको महातपाः ।\nतमाश्रित्य प्रवर्तस्व ततः सम्भाव्यसे जनैः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 22
  },
  {
    "id": 1782985482445,
    "chapter_id": 8,
    "verse_number": "5.23",
    "content_sanskrit": "वेदान्तसूत्रैरस्माकं मतमैकात्म्यगोचरम् ।\nवितत्य सकलान् वेदानतत्वावेदकान् वद",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 23
  },
  {
    "id": 1782985482446,
    "chapter_id": 8,
    "verse_number": "5.24",
    "content_sanskrit": "जीवेभ्योऽन्यो हरिर्ब्रह्म स्रष्टृत्वादिगुणान्वितः ।\nइति वेदान्तसूत्राणां हृदयं च तिरस्कुरु",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 24
  },
  {
    "id": 1782985482447,
    "chapter_id": 8,
    "verse_number": "5.25",
    "content_sanskrit": "अस्मदावेशबलतः कलेः शक्तया च पीडिताः ।\nभवन्ति मलिनात्मानः सज्जनाः साङ्घययोगिनः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 25
  },
  {
    "id": 1782985482448,
    "chapter_id": 8,
    "verse_number": "5.26",
    "content_sanskrit": "मिथ्यावादं ततस्तेऽपि केचिच्छ्रद्दधतेऽपरे ।\nउदासते निराकर्तुं केचिदेव समीहते",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 26
  },
  {
    "id": 1782985482449,
    "chapter_id": 8,
    "verse_number": "5.27",
    "content_sanskrit": "अमभिप्रायात् कर्मतो वा केचिदस्मज्जना भुवि ।\nजाता अन्ये जनिष्यन्ते निःसहायो न जायसे",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 27
  },
  {
    "id": 1782985482450,
    "chapter_id": 8,
    "verse_number": "5.28",
    "content_sanskrit": "इति दैत्यैः समादिष्टो मणिमान् भीमभीमताम् ।\nमनसा शङ्खमानोऽपि भुव्युत्पत्तुं मनो दधे",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 28
  },
  {
    "id": 1782985482451,
    "chapter_id": 8,
    "verse_number": "5.29",
    "content_sanskrit": "तत्काले शाक्यशास्त्रेण विस्तृता सकला मही ।\nवैदिकाश्रमधरमादेः पराभूतिरभूत्ततः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 29
  },
  {
    "id": 1782985482452,
    "chapter_id": 8,
    "verse_number": "5.30",
    "content_sanskrit": "इन्द्रजालैर्वशीकृत्य राजानं सौगतं प्रति ।\nशून्यं तत्वं च संश्राव्य सतस्तेनोदसादयन्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 30
  },
  {
    "id": 1782985482453,
    "chapter_id": 8,
    "verse_number": "5.31",
    "content_sanskrit": "ततो गोविन्दनामाभूदिद्वजो विद्याविशारदः ।\nस चतुर्वर्णजाः कन्या ऊढ्वा पुत्रानजीजनत्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 31
  },
  {
    "id": 1782985482454,
    "chapter_id": 8,
    "verse_number": "5.32",
    "content_sanskrit": "शबरो विक्रमादित्यो हरिश्चन्द्रोऽथ भर्तृहृत् ।\nइत्येते कोविदा आसन् धृतवर्णाश्रमव्रताः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 32
  },
  {
    "id": 1782985482455,
    "chapter_id": 8,
    "verse_number": "5.33",
    "content_sanskrit": "गोविन्दो दारपुत्राद्यं विहायाथाचरन्महीम् ।\nव्यधत्त शबरो भाष्यं सूत्राणां जैमिने रहः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 33
  },
  {
    "id": 1782985482456,
    "chapter_id": 8,
    "verse_number": "5.34",
    "content_sanskrit": "क्ष्मामपाद्विक्रमादित्यो हरिश्चन्द्रः सुरोत्तमान् ।\nइष्ट्वायुर्वेदवशितामलमिष्ट परं वरम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 34
  },
  {
    "id": 1782985482457,
    "chapter_id": 8,
    "verse_number": "5.35",
    "content_sanskrit": "गत्वा यज्ञभुवं भर्तृहरिर्विप्रानुमोदितः ।\nविचार्य यज्ञह्रदयं स चचार महीमिमाम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 35
  },
  {
    "id": 1782985482458,
    "chapter_id": 8,
    "verse_number": "5.36",
    "content_sanskrit": "आर्यस्य वेदविदुषः प्राभूतां तनयावुभौ ।\nभट्टः कुमारः प्रथमः भट्टनारायणः परः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 36
  },
  {
    "id": 1782985482459,
    "chapter_id": 8,
    "verse_number": "5.37",
    "content_sanskrit": "कुमारस्तु तदा भेजे बौद्धं तन्मतवित्तये ।\nनारायणेन सम्मन्त्र्य सम्प्राप्ते धर्मसङ्कटे",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 37
  },
  {
    "id": 1782985482460,
    "chapter_id": 8,
    "verse_number": "5.38",
    "content_sanskrit": "प्रासादाग्रे च शाक्यस्य भट्टोऽभ्यञ्जयिता पदे ।\nवेदविस्रवनव्याख्यां श्रुत्वाश्रूणि न्यपातयत्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 38
  },
  {
    "id": 1782985482461,
    "chapter_id": 8,
    "verse_number": "5.39",
    "content_sanskrit": "तदुष्णिमानुमानेन विप्रस्याधिं विबुद्ध्य सः ।\nहन्यतां हन्यतामेषः जगाद च",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 39
  },
  {
    "id": 1782985482462,
    "chapter_id": 8,
    "verse_number": "5.40",
    "content_sanskrit": "तदानीं हन्तुकामेऽस्मिन् न्यपतद्धरणीतले ।\nभट्टो वेदाः प्रमाणं चेज्जीवामीति वचोऽब्रुवन्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 40
  },
  {
    "id": 1782985482463,
    "chapter_id": 8,
    "verse_number": "5.41",
    "content_sanskrit": "शङ्कुवेधेन तस्यैकं चक्षुर्नष्टं ततोऽभवत् ।\nवेदप्रामाण्यसन्देहात् काणोऽसीत्यशरीरवाक",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 41
  },
  {
    "id": 1782985482464,
    "chapter_id": 8,
    "verse_number": "5.42",
    "content_sanskrit": "क्ताचित्तंरहोराजाक्कुन्त्रचोत्'\nदेवताजनसम्भाव्यं मतं किंस्विद् द्विजेन्द्र ते",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 42
  },
  {
    "id": 1782985482465,
    "chapter_id": 8,
    "verse_number": "5.43",
    "content_sanskrit": "इत्युक्तः स भट्टः स्माहाविशङ्कितः ।\nवर्णाश्रमोचिता धर्मा न हातव्या मुमुक्षुभिः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 43
  },
  {
    "id": 1782985482466,
    "chapter_id": 8,
    "verse_number": "5.44",
    "content_sanskrit": "वेदाः प्रमाणमित्यस्मन्मतं देवानुशिक्षितम् ।\nह्रातव्यं गतिमिच्छद्भिः पुरुषैः सौगतं मतम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 44
  },
  {
    "id": 1782985482467,
    "chapter_id": 8,
    "verse_number": "5.45",
    "content_sanskrit": "यदि प्रसीदसि क्ष्मेश सौगतान् विजयामहे ।\nप्रवेशय न चेदस्मान् वह्नावह्लाय निश्चयात्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 45
  },
  {
    "id": 1782985482468,
    "chapter_id": 8,
    "verse_number": "5.46",
    "content_sanskrit": "इति भट्टवचः श्रुत्वा विस्रम्भेणाब्रवीन्नृपः ।\nयदि जेष्यसि तान् वह्नौ वेशये सौगतानिति",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 46
  },
  {
    "id": 1782985482469,
    "chapter_id": 8,
    "verse_number": "5.47",
    "content_sanskrit": "तस्य राज्ञो वचः श्रुत्वा विस्रब्धः स महीसुरः ।\nसनारायणभट्टः सशबरो मुमुदे भृशम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 47
  },
  {
    "id": 1782985482470,
    "chapter_id": 8,
    "verse_number": "5.48",
    "content_sanskrit": "अपक्षपातिनि क्षत्रे स टीकां तर्ककर्कशाम् ।\nचक्रे शबरभाष्यस्य बौद्धशास्त्रनिकृन्तनीम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 48
  },
  {
    "id": 1782985482471,
    "chapter_id": 8,
    "verse_number": "5.49",
    "content_sanskrit": "नारायणेन भट्टेन स कदाचित् समेयिवान् ।\nतोरणाग्रे पुरद्वारि पत्रिकामप्यपातयत्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 49
  },
  {
    "id": 1782985482472,
    "chapter_id": 8,
    "verse_number": "5.50",
    "content_sanskrit": "वह्लिप्रवेशग्लहया कुमारो\nवितण्डया माध्यमिकान्निगृह्य ।\nनष्टायुषोऽपह्नवतः श्रुतीना-\nमह्नाय वह्नौ गमयाञ्चकार",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 50
  },
  {
    "id": 1782985482473,
    "chapter_id": 8,
    "verse_number": "5.51",
    "content_sanskrit": "सायंत्रिकैः सह ययुः कतिचिन्निलीनाः\nसम्प्राप्तभुक्तिभुवि केचन बङ्कमुख्याः ।\nराज्यान्तवर्त्मसु गताः सुगताः विचेरुः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 51
  }
]