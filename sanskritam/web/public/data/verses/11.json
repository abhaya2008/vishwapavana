[
  {
    "id": 66,
    "chapter_id": 11,
    "verse_number": "8.1",
    "content_sanskrit": "मायाविना समादिष्टा मूर्खाः पत्तलजन्मना ।\nनन्दिग्रामं समासाद्य हंसानामदहन्मठम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 1
  },
  {
    "id": 67,
    "chapter_id": 11,
    "verse_number": "8.2",
    "content_sanskrit": "निजघ्नुर्गोव्रजं ग्रामे भैरव्या बालकानपि ।\nविप्रानज्वरयन् दैत्या अबला उदसादयन्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 2
  },
  {
    "id": 68,
    "chapter_id": 11,
    "verse_number": "8.3",
    "content_sanskrit": "प्राज्ञतीर्थः सशिष्योऽसौ छिन्नदण्डकमण्डलुः ।\nउद्दिश्य प्रस्थितः प्रातः सत्क्षेत्रं पौरुषोत्तमम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 3
  },
  {
    "id": 69,
    "chapter_id": 11,
    "verse_number": "8.4",
    "content_sanskrit": "मायिनस्ताननुद्रुत्य हंसाग्न्यान् विजने स्थले ।\nअभिहत्य निपात्योचुः सम्प्राप्तप्राणसङ्कटान्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 4
  },
  {
    "id": 70,
    "chapter_id": 11,
    "verse_number": "8.5",
    "content_sanskrit": "अस्माननुव्रजध्वं वा म्रियध्वं वा विचिन्त्यताम् ।\nइत्युक्ता तेऽब्रुवन्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 5
  },
  {
    "id": 1782985849927,
    "chapter_id": 11,
    "verse_number": "8.6",
    "content_sanskrit": "अथ ज्ञानोत्तमस्तेभ्यो दत्वा दण्डादिकं खलः ।\nव्यत्यस्य लाञ्छनं चोपदिदेशाकूतमासुरम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 6
  },
  {
    "id": 1782985849928,
    "chapter_id": 11,
    "verse_number": "8.7",
    "content_sanskrit": "तेभ्यस्ते निपुणा हंसाः परमा गूढचेतसः ।\nश्रुत्वा शारीरकं भाष्यं व्याचख्युस्तर्ककर्कशाः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 7
  },
  {
    "id": 1782985849929,
    "chapter_id": 11,
    "verse_number": "8.8",
    "content_sanskrit": "मायिनो वञ्चयित्वैवं सन्तोषविवशाशयान् ।\nआनन्दबालमठगान् न्यवसन् सह ते अमी",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 8
  },
  {
    "id": 1782985849930,
    "chapter_id": 11,
    "verse_number": "8.9",
    "content_sanskrit": "विश्वस्य प्राज्ञतीर्थार्यमैकात्म्योपास्तिनिष्ठितम् ।\nमायावादरतं दृष्टवा मायिनो जह्षुर्मुदा",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 9
  },
  {
    "id": 1782985849931,
    "chapter_id": 11,
    "verse_number": "8.10",
    "content_sanskrit": "तं सशिष्यं सदाचारमवलोक्याथ मायिनः ।\nपानभोगाबलाकाङ्क्षा विहाय प्रययुः शनैः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 10
  },
  {
    "id": 1782985849932,
    "chapter_id": 11,
    "verse_number": "8.11",
    "content_sanskrit": "अयं हि प्राज्ञतीर्थार्यः सदाचारातिकर्कशः ।\nगुरूनस्मान्दुराचारान् गर्हयेदिति भीरवः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 11
  },
  {
    "id": 1782985849933,
    "chapter_id": 11,
    "verse_number": "8.12",
    "content_sanskrit": "प्राज्ञतीर्थस्तदा शिष्यान् हंसानाहूय सम्मतान् ।\nरहस्याह महानेष हरिणानुग्रहः कृतः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 12
  },
  {
    "id": 1782985849934,
    "chapter_id": 11,
    "verse_number": "8.13",
    "content_sanskrit": "बर्बरा मायिनः सर्वे ययुर्विश्वस्य नः सुखम् ।\nपारयित्वा चतुर्मांसव्रतं यामो वयं त्विति",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 13
  },
  {
    "id": 1782985849935,
    "chapter_id": 11,
    "verse_number": "8.14",
    "content_sanskrit": "गत्वा गङ्गां ततः स्नात्वा मुक्तवांऽहो मायिसम्भवम् ।\nमायिव्याजेन यास्यामो नन्दिग्रमं शनैः शनैः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 14
  },
  {
    "id": 1782985849936,
    "chapter_id": 11,
    "verse_number": "8.15",
    "content_sanskrit": "इत्युक्तवा प्राज्ञतीर्थार्यश्चातुर्मास्यादनन्तरम् ।\nगत्वा सशिष्यो गङ्गायां स्नात्वायादुत्तरां दिशम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 15
  },
  {
    "id": 1782985849937,
    "chapter_id": 11,
    "verse_number": "8.16",
    "content_sanskrit": "नन्दिग्रामं समासाद्य हरिं संस्मार्य सज्जनान् ।\nनिरोगानकरोदार्या रहो नाथमसेवयत्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 16
  },
  {
    "id": 1782985849938,
    "chapter_id": 11,
    "verse_number": "8.17",
    "content_sanskrit": "प्राज्ञतीर्थश्च तच्छिष्या भक्तया सम्भाजिता जनैः ।\nबदर्यां मुनयः स्नात्वा तीर्थे तीव्रं तपोऽचरन्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 17
  },
  {
    "id": 1782985849939,
    "chapter_id": 11,
    "verse_number": "8.18",
    "content_sanskrit": "नारायण नमस्तुभ्यं नमो वस्तात्विकाः सुराः ।\nहा हा नः सुगतिं देहि गुरो नाथेति चक्रुशुः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 18
  },
  {
    "id": 1782985849940,
    "chapter_id": 11,
    "verse_number": "8.19",
    "content_sanskrit": "तेषामाविरभूत्सत्यप्रज्ञः साकं महर्षिभिः ।\nतस्मै हंसा द्रुतं नेमुः सर्वे ते दैत्यपीडिताः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 19
  },
  {
    "id": 1782985849941,
    "chapter_id": 11,
    "verse_number": "8.20",
    "content_sanskrit": "क्रदन्तः पतितान् भूमौ सत्यप्रज्ञो महत्तपाः ।\nआज्ञायोत्थापयामास जनांस्तेषां महद्भयम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 20
  },
  {
    "id": 1782985849942,
    "chapter_id": 11,
    "verse_number": "8.21",
    "content_sanskrit": "उपविश्यासने तस्मिन्नुपवेश्य च तान् मुनीन् ।\nउवाचाहं भयं वेन्नि भवतां तपसाखिलम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 21
  },
  {
    "id": 1782985849943,
    "chapter_id": 11,
    "verse_number": "8.22",
    "content_sanskrit": "अयं कालः कलेः साक्षात् तेन चोपद्रुता जनाः ।\nवत्सा विमुञ्चतात्युग्रं तत्वविस्रवसङ्कटम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 22
  },
  {
    "id": 1782985849944,
    "chapter_id": 11,
    "verse_number": "8.23",
    "content_sanskrit": "तवामी प्राज्ञतीर्थान्तेवासिनः पौरुषोत्तमे ।\nक्षेत्रे यान्तु परां सिद्धिमुपास्य पुरुषोत्तमम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 23
  },
  {
    "id": 1782985849945,
    "chapter_id": 11,
    "verse_number": "8.24",
    "content_sanskrit": "शिष्येष्वेकः श्रुतीनां ते सम्प्रदायाभिगुप्तये ।\nचरतां मायिभिः सार्धं तेषां छन्दानुवर्तनैः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 24
  },
  {
    "id": 1782985849946,
    "chapter_id": 11,
    "verse_number": "8.25",
    "content_sanskrit": "संन्यासयेत्स निपुणमेकं वंशधरं द्विजम् ।\nसोऽप्यन्यमन्यं सोऽपीति वंशो न स्यादखण्डितः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 25
  },
  {
    "id": 1782985849947,
    "chapter_id": 11,
    "verse_number": "8.26",
    "content_sanskrit": "नारायणः परः स्वामी सत्यज्ञानादिसङ्गृणः ।\nतस्य दासोऽस्म्यहं सत्यमित्युपासा प्रवर्तताम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 26
  },
  {
    "id": 1782985849948,
    "chapter_id": 11,
    "verse_number": "8.27",
    "content_sanskrit": "मायिनां लाञ्छनं धार्यं कार्यं तन्नमनादिकम् ।\nस्मृत्वा हरिं तदन्तस्थं मायावादञ्च पद्यताम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 27
  },
  {
    "id": 1782985849949,
    "chapter_id": 11,
    "verse_number": "8.28",
    "content_sanskrit": "महासुरमये लोके नैवाविष्कर्तुमर्हसि ।\nभैरव्या वा कृपाण्या वा मायिनो घ्नन्ति वैदिकान्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 28
  },
  {
    "id": 1782985849950,
    "chapter_id": 11,
    "verse_number": "8.29",
    "content_sanskrit": "तेभ्यो गोपायतात्मानं सम्प्रदायं न मुञ्चत ।\nइत्युक्तवा सत्यसंवित्तं त्याज्यं दण्डपटादिकम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 29
  },
  {
    "id": 1782985849951,
    "chapter_id": 11,
    "verse_number": "8.30",
    "content_sanskrit": "मायिदत्तं पुनस्तेभ्यो दण्डाद्यं पूर्ववद्ददौ ।\nताननुज्ञाप्य सत्यात्मा पूर्ववत् स तिरोदधे",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 30
  },
  {
    "id": 1782985849952,
    "chapter_id": 11,
    "verse_number": "8.31",
    "content_sanskrit": "प्राज्ञशिष्या ययुः क्षेत्रं विरक्ताः पौरुषोत्तमम् ।\nप्राज्ञो गुरूपदिष्टेन मार्गेणोवास मायिभिः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 31
  },
  {
    "id": 1782985849953,
    "chapter_id": 11,
    "verse_number": "8.32",
    "content_sanskrit": "एकं वंशधरं शिष्यं कृत्वोपास्तिमशिक्षयत् ।\nअन्यं संन्यस्य सोऽपि स्वं सम्प्रदायमशिक्षयत्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 32
  },
  {
    "id": 1782985849954,
    "chapter_id": 11,
    "verse_number": "8.33",
    "content_sanskrit": "सोऽप्यन्यमित्ययं वंशो नोदछ्छिद्यत भाग्यतः ।\nततः केवलवंशेऽस्मिन् मायिभिः स्वजनभ्रमात्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 33
  },
  {
    "id": 1782985849955,
    "chapter_id": 11,
    "verse_number": "8.34",
    "content_sanskrit": "गृह्यमाणोऽच्युतप्रेक्षः पारिव्राज्यमुपागमत्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 34
  },
  {
    "id": 1782985849956,
    "chapter_id": 11,
    "verse_number": "8.35",
    "content_sanskrit": "अथासुराणां श्रुतिदूषकाणां\nउत्सादनायार्थयतः सुरेन्द्रान् ।\nआनन्दयन् श्रीदयिताज्ञयेशः\nसञ्जीवनात्मावततार भूमौ",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 35
  },
  {
    "id": 1782985849957,
    "chapter_id": 11,
    "verse_number": "8.36",
    "content_sanskrit": "स भगवानुपनीतिमितः पितुः\nसकलदेवसुलक्षणशिक्षणः ।\nअधृत पारमहंस्यमथाश्रमं\nयतिवरात्परमच्युतचेतसः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 36
  },
  {
    "id": 1782985849958,
    "chapter_id": 11,
    "verse_number": "8.37",
    "content_sanskrit": "प्रवर्तिता या सनकादिभिः पुरा\nततः परस्तात्परतीर्थशिष्यकैः ।\nहरेरुपास्तिं स्वगुरुप्रसादितां\nमध्वाय भक्त्योपदिदेश हंसराट्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 37
  },
  {
    "id": 1782985849959,
    "chapter_id": 11,
    "verse_number": "8.38",
    "content_sanskrit": "गुणाननन्तानुपसंहररन् हरे-\nरनन्तरूपेषु दुरन्तसन्ततेः ।\nअनन्तरूपो भगवाननन्तधी-\nरुपास्त शर्वादिसुपर्वणां गुरुः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 38
  },
  {
    "id": 1782985849960,
    "chapter_id": 11,
    "verse_number": "8.39",
    "content_sanskrit": "दस्योर्मणिमत उदितं दुर्भाष्यं व्यस्य मध्व आराध्यः ।\nवेदान्तसूत्रभाष्यं सकलश्रुतितर्कबृंहितं चक्रे",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 39
  },
  {
