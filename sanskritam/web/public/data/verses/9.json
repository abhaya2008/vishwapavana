[
  {
    "id": 61,
    "chapter_id": 9,
    "verse_number": "6.1",
    "content_sanskrit": "उदजृम्भन्त वेदान्ता धर्मा वर्णाश्रमोचिताः ।\nब्राह्मणास्तुतुषुर्यज्ञाः प्रावर्तन्त महीतले",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 1
  },
  {
    "id": 62,
    "chapter_id": 9,
    "verse_number": "6.2",
    "content_sanskrit": "विमृश्य भारविर्भाट्टं समुदासे निरीश्वरम् ।\nशुश्राव तन्निराकर्तुं मात्सर्येण प्रभाकरः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 2
  },
  {
    "id": 1782985647909,
    "chapter_id": 9,
    "verse_number": "6.3",
    "content_sanskrit": "माघो वररुचिर्बाणो मयूरः कालिदासकः ।\nप्रचण्डकोविदा दण्डिमुख्याश्चैतदुदासत",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 3
  },
  {
    "id": 1782985647910,
    "chapter_id": 9,
    "verse_number": "6.4",
    "content_sanskrit": "डम्बकस्तर्कवित्तन्त्री प्रभाकृत्तर्कतन्त्रवित् ।\nमण्डनो रेफणञ्चैते भट्टाद्भाट्टठमशृण्वत",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 4
  },
  {
    "id": 1782985647911,
    "chapter_id": 9,
    "verse_number": "6.5",
    "content_sanskrit": "ततः प्राभाकरं चक्रे व्यर्थयुक्तिः प्रभाकरः ।\nभट्टसम्रब्धमात्सर्यो बहुतन्त्रप्रपञ्चनम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 5
  },
  {
    "id": 1782985647912,
    "chapter_id": 9,
    "verse_number": "6.6",
    "content_sanskrit": "तमेव समयं दैत्यो मणिमानप्यजायत ।\nमनोरथेन महता ब्राह्मण्यां जारतः खलात्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 6
  },
  {
    "id": 1782985647913,
    "chapter_id": 9,
    "verse_number": "6.7",
    "content_sanskrit": "उत्पन्नः सङ्करात्मायं सर्वकर्मबहिष्कृतः ।\nइत्युक्तः स्वजनैर्माता सङ्करेत्याजुहाव तम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 7
  },
  {
    "id": 1782985647914,
    "chapter_id": 9,
    "verse_number": "6.8",
    "content_sanskrit": "विश्वस्ता स्वसुतं दृष्टवा तुष्टा सा पोषयत्क्रमात् ।\nमण्डोदुम्बरनिष्पावैः शिग्रुशाकैरलाम्बुभिः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 8
  },
  {
    "id": 1782985647915,
    "chapter_id": 9,
    "verse_number": "6.9",
    "content_sanskrit": "पञ्चषाण्यानय क्षिप्रं वृन्ताकानीति चोदितः ।\nमात्रा सञ्जग्मिवान् बालो वृन्ताकस्तम्बसञ्जयम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 9
  },
  {
    "id": 1782985647916,
    "chapter_id": 9,
    "verse_number": "6.10",
    "content_sanskrit": "गणयामास वृन्ताकमेकमेकमिति स्फुटम् ।\nएक्तासङ्गून्ययाचात्रनद्वितीक्मचैक्षत",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 10
  },
  {
    "id": 1782985647917,
    "chapter_id": 9,
    "verse_number": "6.11",
    "content_sanskrit": "तदाह मातरं पुत्रो नेक्षे वृन्ताकयोर्द्वयम् ।\nपञ्चषाणि कथं तानि त्वानयेयं तरामिति",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 11
  },
  {
    "id": 1782985647918,
    "chapter_id": 9,
    "verse_number": "6.12",
    "content_sanskrit": "पथिकास्तदुपश्रुत्य प्रहस्य मिथ ऊचिरे ।\nएकस्मिन् द्वित्वसङ्घयां तु कः पश्यति तरामिति",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 12
  },
  {
    "id": 1782985647919,
    "chapter_id": 9,
    "verse_number": "6.13",
    "content_sanskrit": "उपनीय द्विजः कश्चिद वाचाटं निपुणं वटुम् ।\nसुभिक्षान्नघृतक्षीरं सौराष्ट्रमनयत्ततः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 13
  },
  {
    "id": 1782985647920,
    "chapter_id": 9,
    "verse_number": "6.14",
    "content_sanskrit": "प्राग्भवे सुचिरं चीर्णतपस्तुष्टस्य शूलिनः ।\nवरप्रसादतः शीघ्रमध्यगीष्टागमान् वटुः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 14
  },
  {
    "id": 1782985647921,
    "chapter_id": 9,
    "verse_number": "6.15",
    "content_sanskrit": "ततः सौमीं दिशं यातो नदीं तर्तुमवातरत् ।\nतस्या औओघैर्हृते ब्रह्मसूत्रे तामुत्ततार सः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 15
  },
  {
    "id": 1782985647922,
    "chapter_id": 9,
    "verse_number": "6.16",
    "content_sanskrit": "मं त्वं त्यजसि चेत्सूत्रं त्वां प्रागेवाहमत्यजम् ।\nअकर्मणस्त्वया किं म इत्युक्तः स ययौ द्रुतम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 16
  },
  {
    "id": 1782985647923,
    "chapter_id": 9,
    "verse_number": "6.17",
    "content_sanskrit": "दुर्वाससः परं शिष्यं परतीर्थाभिधं यतिम् ।\nचातुर्मास्यव्रतधरमपश्यत् कापटो वटुः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 17
  },
  {
    "id": 1782985647924,
    "chapter_id": 9,
    "verse_number": "6.18",
    "content_sanskrit": "निःसूत्रं तं वटु दृष्टवा महादानवलक्षणम् ।\nबिद्वानबङ्मुररोमूत्वाप्तआचम्यमठंक्यों",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 18
  },
  {
    "id": 1782985647925,
    "chapter_id": 9,
    "verse_number": "6.19",
    "content_sanskrit": "दोषज्ञं तं मुनिं ज्ञात्वा गोदावरीं ययौ ।\nबदर्यां परतीर्थार्यशिष्यं प्राप्येदमब्रवीत्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 19
  },
  {
    "id": 1782985647926,
    "chapter_id": 9,
    "verse_number": "6.20",
    "content_sanskrit": "त्वङ्गुरोरस्मि शिष्योऽहं तदादेशादिहागतः ।\nइत्युक्तवति तस्मिन् स विस्रंभं नैव जग्मिवान्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 20
  },
  {
    "id": 1782985647927,
    "chapter_id": 9,
    "verse_number": "6.21",
    "content_sanskrit": "सत्यप्रज्ञो भक्तिवैराग्यादिगुणोज्झितम् ।\nदुष्टं विज्ञाय तत्याज जुगुप्सां परमां गतः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 21
  },
  {
    "id": 1782985647928,
    "chapter_id": 9,
    "verse_number": "6.22",
    "content_sanskrit": "अतीतजन्मसंस्कारवशादॆकात्म्यभावनाम् ।\nचकार शून्यभावेन निर्गुणत्वेन वा क्वचित्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 22
  },
  {
    "id": 1782985647929,
    "chapter_id": 9,
    "verse_number": "6.23",
    "content_sanskrit": "सहायं मार्गयामास दुष्टपक्षैकदीक्षितः ।\nएकाकी मलिनो मुण्डस्तत्र तत्र परिभ्रमन्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 23
  },
  {
    "id": 1782985647930,
    "chapter_id": 9,
    "verse_number": "6.24",
    "content_sanskrit": "कदाचिन्निशि सङ्गत्य दैत्यास्तं समभावयन् ।\nऊचुश्च सङ्कराचार्य त्वमस्माकं परा गतिः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 24
  },
  {
    "id": 1782985647931,
    "chapter_id": 9,
    "verse_number": "6.25",
    "content_sanskrit": "तुभ्यं मनस्विने भूयः स्वस्ति पादतलोटज ।\nसाघकं प्रत्ययामस्त्वामासुर्याः कार्यसम्पदः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 25
  },
  {
    "id": 1782985647932,
    "chapter_id": 9,
    "verse_number": "6.26",
    "content_sanskrit": "पुरा भट्टभयाच्छाक्या नष्टा द्वीपान्तरं गताः ।\nनारायणोऽन्वगात्तेषां ततोऽप्युत्सादनेच्छया",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 26
  },
  {
    "id": 1782985647933,
    "chapter_id": 9,
    "verse_number": "6.27",
    "content_sanskrit": "तत उत्साद्य तान् भट्ट आयातमनुजं निजम् ।\nदुष्टदेशे चिरावासान्नग्रहीद्दोषशङ्कया",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 27
  },
  {
    "id": 1782985647934,
    "chapter_id": 9,
    "verse_number": "6.28",
    "content_sanskrit": "ततः स सौगतमतं पुनः किञ्चिदुदग्रहीत् ।\nबङ्कस्वामी ततो द्वीपादाजगामातिशङ्कितः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 28
  },
  {
    "id": 1782985647935,
    "chapter_id": 9,
    "verse_number": "6.29",
    "content_sanskrit": "कुमारः स्वमृतिं लोके ख्यापयामास शिष्यकैः ।\nनारायणस्तु तच्छृत्वा शोकात् पावकमाविशत्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 29
  },
  {
    "id": 1782985647936,
    "chapter_id": 9,
    "verse_number": "6.30",
    "content_sanskrit": "आपणेषु ततो बक्कः प्रावर्तयत सौगतम् ।\nमतं लिङ्गान्तरधरैर्जनैः केरलजन्मभिः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 30
  },
  {
    "id": 1782985647937,
    "chapter_id": 9,
    "verse_number": "6.31",
    "content_sanskrit": "गौडपादस्ततो न्यासमियेष प्रवयास्तदा ।\nतच्छृत्वा यतिरूपेण बङ्को गत्वा तमब्रवीत्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 31
  },
  {
    "id": 1782985647938,
    "chapter_id": 9,
    "verse_number": "6.32",
    "content_sanskrit": "सनत्कुमारो भगवान् प्रेषयामास मां तव ।\nमोक्षप्रवर्तनायैव द्वतभावेन किं फलम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 32
  },
  {
    "id": 1782985647939,
    "chapter_id": 9,
    "verse_number": "6.33",
    "content_sanskrit": "इत्युक्तो गौडपादस्तु सम्भ्रमेण ननाम तम् ।\nविप्रस्तुर्याश्रमं प्राप्य तत्त्वं शुश्राव बङक्कतः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 33
  },
  {
    "id": 1782985647940,
    "chapter_id": 9,
    "verse_number": "6.34",
    "content_sanskrit": "तद्दिवर्तप्रपञ्चोऽयं बाध्यते ज्ञानसम्पदि ।\nज्ञानं तु तप्तलोहाप्तजलन्यायेन शाम्यति",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 34
  },
  {
    "id": 1782985647941,
    "chapter_id": 9,
    "verse_number": "6.35",
    "content_sanskrit": "यथा प्रत्याययत्येते सर्वं बाधोपलक्षणम् ।\nततस्त्वमन्यथा तत्त्वं सोऽहमित्यूहमर्हेसि",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 35
  },
  {
    "id": 1782985647942,
    "chapter_id": 9,
    "verse_number": "6.36",
    "content_sanskrit": "इति बङक्कोदितं तत्त्वं विचार्य सुचिरं द्विजः ।\nसर्वभावं निर्विशेषं विना नान्यदवैक्षत",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 36
  },
  {
    "id": 1782985647943,
    "chapter_id": 9,
    "verse_number": "6.37",
    "content_sanskrit": "गोविन्दस्तं समासाद्य ततः संन्यासमाचरत् ।\nसम्प्रदायगतं तत्त्वं श्रुत्वोपास्त यथार्थतः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 37
  },
  {
    "id": 1782985647944,
    "chapter_id": 9,
    "verse_number": "6.38",
    "content_sanskrit": "गोविन्दस्वामिनं साधुं तं गुरुं समुपैहि भो ।\nततो दण्डादिकं प्राप्य शृणु त्वं तत्त्वमुत्तमम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 38
  },
  {
    "id": 1782985647945,
    "chapter_id": 9,
    "verse_number": "6.39",
    "content_sanskrit": "मनः प्रविश्य सर्वेषां त्वं वयं रोचयामहे ।\nविष्णोर्विदूषय गुणानित्युक्तवा ययुरासुराः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 39
  },
  {
    "id": 1782985647946,
    "chapter_id": 9,
    "verse_number": "6.40",
    "content_sanskrit": "वटुः शठः स गोविन्दस्वामिनं प्रैक्षत क्वचित् ।\nभूयासं भवतः शिष्यो न गुरुः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 40
  },
  {
    "id": 1782985647947,
    "chapter_id": 9,
    "verse_number": "6.41",
    "content_sanskrit": "इत्यूचिवांसं गोविन्दः स तं पर्यग्रहीद्द्रुतम् ।\nप्रच्छाद्य शून्यवादित्वं वेदान्तिव्यपदेशतः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 41
  },
  {
    "id": 1782985647948,
    "chapter_id": 9,
    "verse_number": "6.42",
    "content_sanskrit": "वर्तयामो मतं स्वीयमन्यथा गर्हयन्ति नः ।\nतदर्थं सूत्रहृदयं ब्रह्मदत्ताच्छूणोम्यहम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 42
  },
  {
    "id": 1782985647949,
    "chapter_id": 9,
    "verse_number": "6.43",
    "content_sanskrit": "इति गोविन्दमाभाष्य मायी सिद्धान्तिनं ययौ ।\nप्रभाकरकुमाराभ्यां साकं भास्करसंयुतः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 43
  },
  {
    "id": 1782985647950,
    "chapter_id": 9,
    "verse_number": "6.44",
    "content_sanskrit": "शुश्राव सूत्रभावं स ब्रह्मदत्तात्त्रिदण्डिनः ।\nशिष्यास्ते प्रययुः सर्वे विभिन्नमतयो मिथः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 44
  },
  {
    "id": 1782985647951,
    "chapter_id": 9,
    "verse_number": "6.45",
    "content_sanskrit": "भाट्टं शिष्येषु विन्यस्य भट्टो दॆवमसेवत ।\nगुरुः प्राभाकरं तेने भारवेरनुजः शठः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 45
  },
  {
    "id": 1782985647952,
    "chapter_id": 9,
    "verse_number": "6.46",
    "content_sanskrit": "सूत्रैः प्रपञ्चयाञ्चक्रे मायावी सौगतं मतम् ।\nशून्यं ब्रह्मपदेनोक्तवा तथाविद्येति संवृतिम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 46
  },
  {
    "id": 1782985647953,
    "chapter_id": 9,
    "verse_number": "6.47",
    "content_sanskrit": "सत्वादिधर्मराहित्यं शून्यतायै जगाद सः ।\nसूत्रमुद्धूत्य सिद्धान्तमुत्सूत्रैः स्वीयमुच्चकैः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 47
  },
  {
    "id": 1782985647954,
    "chapter_id": 9,
    "verse_number": "6.48",
    "content_sanskrit": "आभाष्य बहुभिः शब्दैः कथं वेदान्तितामियात् ।\nअतत्वावेदकाः प्रायो वेदाः केचिन्निरर्थकाः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 48
  },
  {
    "id": 1782985647955,
    "chapter_id": 9,
    "verse_number": "6.49",
    "content_sanskrit": "इति वेदान्तवादः स्यात्कथं वादस्तदन्तकः ।\nकर्णौ प्यधत्त सिद्धान्ती भाष्यं तच्छुश्रुवान् मनाक्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 49
  },
  {
    "id": 1782985647956,
    "chapter_id": 9,
    "verse_number": "6.50",
    "content_sanskrit": "भास्करः तदखण्डयत् ।\nदुःशास्त्रमपठन् दॆत्यास्तत एव हररिद्विषः ।\nअसुरावेशिनः सर्वे सङ्करस्य वशं गताः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 50
  },
  {
    "id": 1782985647957,
    "chapter_id": 9,
    "verse_number": "6.51",
    "content_sanskrit": "जन्तून् सवर्त्मबाह्यानपि हन्तुमिच्छन् ।\nशाक्तेयमन्त्रानभजत्स मायी\nसा भैरवी तस्य चकार दौत्यम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 51
  }
]