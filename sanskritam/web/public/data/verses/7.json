[
  {
    "id": 53,
    "chapter_id": 7,
    "verse_number": "4.1",
    "content_sanskrit": "कृष्णायाः कालियं त्यक्त्वा पीत्वा दावाग्निमुल्बणम्  ।\nस विषद्रुममुच्छिद्य दैत्यान्गोवपुषोहनत्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 1
  },
  {
    "id": 54,
    "chapter_id": 7,
    "verse_number": "4.2",
    "content_sanskrit": "स सप्तोक्षवधाल्लेभे नीलां गोपालकन्यकां  ।\nबलेन धेनुकां हत्वा जघानान्यान्खरान्स्वयम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 2
  },
  {
    "id": 55,
    "chapter_id": 7,
    "verse_number": "4.3",
    "content_sanskrit": "दौत्येन वञ्चयित्वारीन् प्रायो भीमेन सर्वराः ।जघान कृतसारथ्यो जिष्णोः पार्थानपाद्धरिः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 3
  },
  {
    "id": 56,
    "chapter_id": 7,
    "verse_number": "4.4",
    "content_sanskrit": "अथाभिमन्योस्तनयः परीक्षित् राजासवज्रो जगतीं विजित्य । सर्वात्मभावं परमे दधानः सम्राजलक्ष्मीमुपलभ्य रेमे",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 4
  },
  {
    "id": 1782985326707,
    "chapter_id": 7,
    "verse_number": "4.5",
    "content_sanskrit": "मखभङ्गरुषेन्द्रेणादिष्टैर्मेघैः कृतां हरिः  ।\nवृष्टिं सोढुमशाक्तान्स्वान् ररक्षोधृत्य पर्वतम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 5
  },
  {
    "id": 1782985326708,
    "chapter_id": 7,
    "verse_number": "4.6",
    "content_sanskrit": "आर्यानुग्रहसम्प्राप्तकामा गोपाङ्गनास्ततः ।\nरमयामासगोविन्दश्चिरमैषीषु रात्रिषु",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 6
  },
  {
    "id": 1782985326709,
    "chapter_id": 7,
    "verse_number": "4.7",
    "content_sanskrit": "सुरूपीणां च गोपीनां मण्डले भगवान् स्वयम् ।\nननर्त वेणुना गायन् रासक्रीडामहेत्सवे",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 7
  },
  {
    "id": 1782985326710,
    "chapter_id": 7,
    "verse_number": "4.8",
    "content_sanskrit": "शङ्खचूडासुरं हत्वारिष्टं केशिनमप्यथ ।\nमयपुत्रं पुनर्व्योमं स चक्रे व्रजरक्षणम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 8
  },
  {
    "id": 1782985326711,
    "chapter_id": 7,
    "verse_number": "4.9",
    "content_sanskrit": "कंसप्रेरितमक्रूरं दृष्वा सम्भाव्य तं हरिः ।\nतेन साकं ययो देवः मधुरां बलसंयुतः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 9
  },
  {
    "id": 1782985326712,
    "chapter_id": 7,
    "verse_number": "4.10",
    "content_sanskrit": "भङ्खा कंसधनुर्शार्वं हत्वाम्बष्टं सवारणम् ।\nचाणूरमुष्टिको हत्वा सबलः शुशुभे हरिः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 10
  },
  {
    "id": 1782985326713,
    "chapter_id": 7,
    "verse_number": "4.11",
    "content_sanskrit": "मञ्चस्थं मातुलं कंसं मूर्धि संगृह्य माघवः ।\nनिपात्य निष्पिपेषोच्चैः धरण्यां स ममार च",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 11
  },
  {
    "id": 1782985326714,
    "chapter_id": 7,
    "verse_number": "4.12",
    "content_sanskrit": "तद्बलं सकलं हत्वा जनान्सर्वाननन्दयत्  ।\nविमुच्य निगडादीशाः पितरावभ्यवन्दत",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 12
  },
  {
    "id": 1782985326715,
    "chapter_id": 7,
    "verse_number": "4.13",
    "content_sanskrit": "पुत्रीवेधव्यसंकृद्धमभियान्तं जरासुतम्  ।\nसबलोभ्यर्दयत् कृष्णो हत्वा तत्सैनिकान् मुहुः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 13
  },
  {
    "id": 1782985326716,
    "chapter_id": 7,
    "verse_number": "4.14",
    "content_sanskrit": "पाण्डुर्वने मृतः पार्था आनीता मुनिभिः पुरम्  ।\nपीड्यन्ते कुरुभिः स्वैरमित्याश्रावि मधुद्विषा",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 14
  },
  {
    "id": 1782985326717,
    "chapter_id": 7,
    "verse_number": "4.15",
    "content_sanskrit": "अक्रूरं प्रेषयामास कृष्णो नागपुरं प्रति ।\nकुरूणामनयं ज्ञात्वा धृतराष्ट्रमुवाच सः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 15
  },
  {
    "id": 1782985326718,
    "chapter_id": 7,
    "verse_number": "4.16",
    "content_sanskrit": "तव पुत्रा न सन्त्येव भीमसेनाग्निभस्मिताः ।\nइत्युक्ता भीमपार्थाभ्यां सहितः प्रययौ पुरीम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 16
  },
  {
    "id": 1782985326719,
    "chapter_id": 7,
    "verse_number": "4.17",
    "content_sanskrit": "पूजयन्तौ हरि पार्थौ पूजितौ सर्वयादवैः ।\nऊषतुः सुचिरं तत्र भक्तिज्ञानामृताशनो",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 17
  },
  {
    "id": 1782985326720,
    "chapter_id": 7,
    "verse_number": "4.18",
    "content_sanskrit": "उद्धवं प्रेषयामास व्रजशोकापनुत्तये ।\nभगवान् मगधाधीशं पुनरभ्यर्दयद्युघि",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 18
  },
  {
    "id": 1782985326721,
    "chapter_id": 7,
    "verse_number": "4.19",
    "content_sanskrit": "ससृगालाघिपं हत्वा तत्पुत्रं पयपालयत् ।\nइति चित्राणि कर्माणि चकार पुरुषोत्तमः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 19
  },
  {
    "id": 1782985326722,
    "chapter_id": 7,
    "verse_number": "4.20",
    "content_sanskrit": "भीष्मकस्य सुतां देवीं रुक्मिणीमवहत्ततः ।\nविज्ञानानन्दरूपिण्या स रेमे रमया तया",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 20
  },
  {
    "id": 1782985326723,
    "chapter_id": 7,
    "verse_number": "4.21",
    "content_sanskrit": "लब्धं सत्राजिता सूर्यात्सः सिंहापहृतं ततः ।\nरत्नं जाम्बवतानीतं जाम्बवत्या सहानयत्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 21
  },
  {
    "id": 1782985326724,
    "chapter_id": 7,
    "verse_number": "4.22",
    "content_sanskrit": "सत्राजिते ददौ रत्नं तेन दत्तां सरत्नकां ।\nसत्यभामामुदवहत् सक्षाल्लक्ष्मीं परात्पराम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 22
  },
  {
    "id": 1782985326725,
    "chapter_id": 7,
    "verse_number": "4.23",
    "content_sanskrit": "हतवान् सानुजं हंसं कृष्णो रेमे स्वघामनि ।\nपुत्रान् प्रद्युम्नसाम्बदीन् रुक्मिण्याद्यास्वजीजनत्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 23
  },
  {
    "id": 1782985326726,
    "chapter_id": 7,
    "verse_number": "4.24",
    "content_sanskrit": "पाण्डवा द्रोणमासाद्य कृतशस्त्रास्त्रशिक्षणाः ।\nसर्वविध्यातिशयिनो मुमुदुः कृष्णसंगताः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 24
  },
  {
    "id": 1782985326727,
    "chapter_id": 7,
    "verse_number": "4.25",
    "content_sanskrit": "संभाविता भगवता पाण्डवा स्नेहसंभृताः ।\nअनुज्ञाता पुरं जग्मुः सदातद्भावतत्पराः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 25
  },
  {
    "id": 1782985326728,
    "chapter_id": 7,
    "verse_number": "4.26",
    "content_sanskrit": "स्वामित्वेन सुहृत्वेन बन्धुत्वेन च पाण्डवाः ।\nसखत्वेन गतित्वेन तमेव शरणं ययुः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 26
  },
  {
    "id": 1782985326729,
    "chapter_id": 7,
    "verse_number": "4.27",
    "content_sanskrit": "पुरान्निर्यापिता दुष्टैः हिडिम्बं च बकं तथा ।\nनिहत्य पाण्डवाः प्रापुः कृष्णं कृष्णास्वयम्बरे",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 27
  },
  {
    "id": 1782985326730,
    "chapter_id": 7,
    "verse_number": "4.28",
    "content_sanskrit": "लब्धकृष्णाननुज्ञाप्य पाण्डवान्स्वपुरं गतः ।\nनिहत्य शतधन्वानं पार्थानामन्तिकं ययौ",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 28
  },
  {
    "id": 1782985326731,
    "chapter_id": 7,
    "verse_number": "4.29",
    "content_sanskrit": "कारयित्वा हरिप्रस्थं तत्र पाथान्निवेश्य सः ।\nउपयम्य च कालिन्दीं द्वारकामाप माघवः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 29
  },
  {
    "id": 1782985326732,
    "chapter_id": 7,
    "verse_number": "4.30",
    "content_sanskrit": "नीलां नग्नजितः पुत्रीं मित्रविन्दां पिन्रुष्वसु ।\nभद्रां च केकयसुतां लक्ष्मणाख्यां च सो वहत्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 30
  },
  {
    "id": 1782985326733,
    "chapter_id": 7,
    "verse_number": "4.31",
    "content_sanskrit": "सोऽथाश्चर्यतमो धन्यो भौमं हत्वा दिवं गतः ।\nअपाहपरत् पारिजातं पराजित्य पुरन्दरम्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 31
  },
  {
    "id": 1782985326734,
    "chapter_id": 7,
    "verse_number": "4.32",
    "content_sanskrit": "महिषीणां सहस्राणि षोडशाद्हवच्युतः ।\nशतं ड तासु प्रत्येकं पुत्रा दश दशाभवन्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 32
  },
  {
    "id": 1782985326735,
    "chapter_id": 7,
    "verse_number": "4.33",
    "content_sanskrit": "द्यूते जिताः कृतारण्यवासा अज्ञातवासतः ।\nपारंगता उपछ्लाव्ये पार्थास्तं प्रति लेभिरे",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 33
  },
  {
    "id": 1782985326736,
    "chapter_id": 7,
    "verse_number": "4.34",
    "content_sanskrit": "दौत्येन वञ्चयित्वारीन् प्रायो भीमेन सर्वराः  ।\nजघान कृतसारथ्यो जिष्णोः पार्थानपाद्धरिः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 34
  },
  {
    "id": 1782985326737,
    "chapter_id": 7,
    "verse_number": "4.35",
    "content_sanskrit": "वायुर्वंशानिवान्योन्यं प्रतिघट्टनसम्भवैः ।\nवैरवैश्वानरज्वालैस्सञ्जहार हरिरयदून्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 35
  },
  {
    "id": 1782985326738,
    "chapter_id": 7,
    "verse_number": "4.36",
    "content_sanskrit": "उद्धवं सनकादींश्च दूर्वासप्रभृतींश्च सः ।\nन्ययुङ्ग सववेदान्तवर्तने सहशिष्यकान्",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 36
  },
  {
    "id": 1782985326739,
    "chapter_id": 7,
    "verse_number": "4.37",
    "content_sanskrit": "एवं चित्रचरित्रस्तु कृष्णोनुज्ञाप्य पाण्डवान् ।\nरूपेणेकेनास भूमावेकेन त्रिदिवं गतः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 37
  },
  {
    "id": 1782985326740,
    "chapter_id": 7,
    "verse_number": "4.38",
    "content_sanskrit": "एवं कृष्णसहायास्ते पार्थाः क्रोधवशादिकान् ।\nश्रीकृष्णद्वेषिणो हत्वा सकृष्णाः कृष्णमन्वयुः",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 38
  },
  {
    "id": 1782985326741,
    "chapter_id": 7,
    "verse_number": "4.39",
    "content_sanskrit": "अथाभिमन्योस्तनयः परीक्षित्\nराजासवज्रो जगतीं विजित्य  ।\nसर्वात्मभावं परमे दधानः\nसम्राजलक्ष्मीमुपलभ्य रेमे",
    "padaccheda": "",
    "anvaya": "",
    "meaning_sanskrit": "",
    "meaning_english": "",
    "audio_url": null,
    "display_order": 39
  }
]